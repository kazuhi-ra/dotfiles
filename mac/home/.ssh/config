# Added by OrbStack: 'orb' SSH host for Linux machines
# This only works if it's at the top of ssh_config (before any Host blocks).
# This won't be added again if you remove it.
Include ~/.orbstack/ssh/config

Host ub
  HostName ub
  User kazuhira

Host github.com
  HostName github.com
  # 鍵は mac/home/.ssh/github.local(git 管理外、chmod 600)
  IdentityFile ~/.ssh/github.local
  User git
  IdentitiesOnly yes
  Compression yes
  AddKeysToAgent yes
