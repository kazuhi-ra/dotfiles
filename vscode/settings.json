{
  "workbench.colorTheme": "Default High Contrast",
  "workbench.preferredDarkColorTheme": "Tomorrow Night Blue",
  "workbench.iconTheme": "vscode-icons",
  "workbench.commandPalette.history": 2000,
  "workbench.startupEditor": "newUntitledFile",
  "workbench.preferredLightColorTheme": "Default High Contrast",
  "workbench.colorCustomizations": {
    "terminal.border": "#5c97f0",
    "editor.lineHighlightBackground": "#182f6ef2",
    "editor.selectionForeground": "#c8c8c870",
    "editor.selectionBackground": "#088cc06f",
    "editor.stackFrameHighlightBackground": "#ccdd3267",
    "editorIndentGuide.activeBackground1": "#cec3c3be",
    "editorIndentGuide.background1": "#afb5b62f",
    "diffEditor.removedTextBorder": "#c292db",
    "diffEditor.insertedTextBorder": "#48c563f5",
    "terminal.foreground": "#c6c8d1",
    "terminalCursor.background": "#c6c8d1",
    "terminalCursor.foreground": "#c6c8d1",
    "terminal.ansiBrightBlack": "#161722",
    "terminal.ansiBrightRed": "#f29b9e",
    "terminal.ansiBrightGreen": "#ccdba0",
    "terminal.ansiBrightYellow": "#edbe9d",
    "terminal.ansiBrightBlue": "#a3bee3",
    "terminal.ansiBrightCyan": "#b6d8de",
    "terminal.ansiBrightMagenta": "#c8b5e6",
    "terminal.ansiBrightWhite": "#e9ebf5",
    "terminal.ansiBlack": "#373757",
    "terminal.ansiRed": "#e27878",
    "terminal.ansiGreen": "#b4be82",
    "terminal.ansiYellow": "#e2a478",
    "terminal.ansiBlue": "#84a0c6",
    "terminal.ansiCyan": "#89b8c2",
    "terminal.ansiMagenta": "#a093c7",
    "terminal.ansiWhite": "#d0d2db",
    "tab.inactiveForeground": "#ffffff88",
    "contrastBorder": "#57d5ffa2",
    "editorSuggestWidget.selectedBackground": "#3e0041c8",
    "editorInlayHint.background": "#ff660000",
    "editorInlayHint.foreground": "#ffffff73",
  },
  "editor.fontFamily": "HackGen Console NF",
  // "editor.fontFamily": "UDEV Gothic 35NFLG",
  "editor.fontLigatures": true,
  "editor.renderWhitespace": "none",
  "editor.tabSize": 2,
  "editor.minimap.enabled": false,
  "editor.suggestSelection": "first",
  "editor.quickSuggestionsDelay": 1,
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
  },
  "editor.tokenColorCustomizations": {
    "variables": "#f8f9f1da",
    "comments": "#796BA7",
    "functions": "#64c574bd",
    "keywords": "#dd69add8",
    "numbers": "#9E76F6",
    "strings": "#55AAAA",
    "types": "#cf714f",
  },
  "[javascript][typescript][typescriptreact][json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "eslint.options": {
    "extensions": [
      ".js",
      ".jsx",
      ".mdx",
      ".ts",
      ".tsx"
    ],
  },
  "eslint.validate": [
    "mdx",
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
  ],
  "[ruby]": {
    "editor.defaultFormatter": "Shopify.ruby-lsp",
    "editor.formatOnSave": true,
    "editor.insertSpaces": true,
    "editor.semanticHighlighting.enabled": true,
    "editor.formatOnType": true,
  },
  "[terraform]": {
    "editor.defaultFormatter": "hashicorp.terraform",
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "file",
  },
  "[terraform-vars]": {
    "editor.defaultFormatter": "hashicorp.terraform",
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "file",
  },
  "rubyLsp.formatter": "auto",
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,
  "git.autofetch": true,
  "git.confirmSync": false,
  "terminal.integrated.fontSize": 15,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.tabs.location": "left",
  "terminal.integrated.tabs.enabled": false,
  "terminal.integrated.enableMultiLinePasteWarning": false,
  "terminal.integrated.shellIntegration.history": 100000,
  "scm.diffDecorationsGutterWidth": 1,
  "prettier.semi": false,
  "prettier.jsxSingleQuote": true,
  "prettier.singleQuote": true,
  "typescript.updateImportsOnFileMove.enabled": "never",
  "files.autoSave": "onFocusChange",
  "files.insertFinalNewline": true,
  "vsicons.dontShowNewVersionMessage": true,
  "liveServer.settings.donotShowInfoMsg": true,
  "security.workspace.trust.untrustedFiles": "open",
  "redhat.telemetry.enabled": false,
  "extensions.ignoreRecommendations": true,
  "diffEditor.ignoreTrimWhitespace": true,
  "editor.inlineSuggest.enabled": true,
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
    "ruby": false,
    "javascript": true,
    "typescript": true,
    "coffeescript": true,
    "latex": true,
    "c": false,
    "todo": false,
    "cpp": false,
    "yaml": false,
    "dart": false,
    "ini": false,
  },
  "editor.linkedEditing": true,
  "editor.fontSize": 14.8,
  "typescript.preferGoToSourceDefinition": true,
  "javascript.preferGoToSourceDefinition": true,
  "window.commandCenter": false,
  "workbench.layoutControl.enabled": false,
  "window.zoomLevel": 1,
  "diffEditor.useInlineViewWhenSpaceIsLimited": false,
  "yaml.schemas": {
    "file:///Users/hashidzumeippei/.vscode/extensions/docsmsft.docs-yaml-1.0.5/dist/toc.schema.json": "/toc\\.yml/i",
  },
  "rust-analyzer.inlayHints.bindingModeHints.enable": true,
  "rust-analyzer.inlayHints.closureCaptureHints.enable": true,
  "editor.stickyScroll.enabled": false,
  "typescript.inlayHints.parameterTypes.enabled": true,
  "typescript.inlayHints.parameterNames.suppressWhenArgumentMatchesName": false,
  "typescript.inlayHints.variableTypes.suppressWhenTypeMatchesName": false,
  "typescript.inlayHints.functionLikeReturnTypes.enabled": true,
  "typescript.inlayHints.variableTypes.enabled": true,
  "git.openRepositoryInParentFolders": "always",
  "terminal.integrated.fontFamily": "HackGen Console NF",
  "terminal.integrated.stickyScroll.enabled": false,
  "todohighlight.keywords": [
    {
      "text": "NOTE:",
      "color": "#fafafa",
      "backgroundColor": "green",
      "overviewRulerColor": "grey",
    },
  ],
  "eslint.format.enable": true,
  "haskell.manageHLS": "PATH",
  "chat.editing.alwaysSaveWithGeneratedChanges": true,
  "githubPullRequests.pullBranch": "never",
  "workbench.editor.doubleClickTabToToggleEditorGroupSizes": "off",
  "editor.acceptSuggestionOnCommitCharacter": false,
  "chat.editor.fontSize": 15,
  "workbench.activityBar.location": "hidden",
  "todohighlight.isEnable": true,
  "docker.extension.enableComposeLanguageServer": false,
  "explorer.confirmPasteNative": false,
  "[dockerfile]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-containers",
  },
  "docker.extension.dockerEngineAvailabilityPrompt": false,
  "github.copilot.nextEditSuggestions.enabled": true,
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "hediet.vscode-drawio.resizeImages": null,
  "chat.viewSessions.orientation": "stacked",
  "claudeCode.preferredLocation": "panel",
  "remote.autoForwardPortsSource": "hybrid",
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilotcli:claude-haiku-4.5",
}
